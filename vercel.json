{
  "buildCommand": "pnpm build",
  "outputDirectory": "app/dist/client",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "app/dist/server/**/*"
    }
  }
}